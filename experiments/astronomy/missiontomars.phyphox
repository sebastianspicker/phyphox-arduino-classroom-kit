<phyphox version="1.7" locale="en">
  <title>Checking a Spaceship Atmosphere</title>
  <category>*Astrolab University of Cologne</category>
    <icon format="base64"></icon>
  <description>
        Testing of self-built spaceship prototypes with the air pressure sensor.

        In this experiment air pressure is used as an analogue for atmosphere and safety questions around a spaceship prototype. Different measurements are performed and compared with reference values. The setup is a classroom model and not a complete mission simulation.

        The same file supports either the phone pressure sensor or the pressure sensor of the TI SensorTag. Both measurement paths record air pressure [hPa] as a function of time [s] and report duration, maximum, minimum, average value, and amount of pressure drop.
  </description>
  <translations>
    <translation locale="de">
      <title>Raumschiffatmosphäre prüfen</title>
      <category>*Astrolabor Universität zu Köln</category>
      <description>
        Überprüfen von selbstgebauten Raumschiff-Prototypen mit dem Luftdrucksensor.

        In diesem Experiment wird der Luftdruck als Analogie für Atmosphären- und Sicherheitsfragen eines Raumschiff-Prototyps untersucht. Verschiedene Messungen werden durchgeführt und mit Referenzwerten verglichen. Der Versuch ist ein Klassenzimmermodell und keine vollständige Missionssimulation.

        Dieselbe Datei unterstützt entweder den Luftdrucksensor des Smartphones oder den Drucksensor des TI SensorTag. Beide Messpfade erfassen den Luftdruck [hPa] in Abhängigkeit von der Zeit [s] und geben Messdauer, Maximum, Minimum, Mittelwert und Höhe des Druckabfalls aus.
    </description>
      <string original="Smartphone Air Pressure Data">Smartphone Luftdruckwerte</string>
      <string original="Use this tab for measurements with the phone pressure sensor.">Nutze diesen Tab für Messungen mit dem Drucksensor des Smartphones.</string>
      <string original="Current value">aktueller Messwert</string>
      <string original="Maximum">Maximum</string>
      <string original="Minimum">Minimum</string>
      <string original="Maximum offset">Maximale Abweichung</string>
      <string original="⌀ Air pressure">⌀-Luftdruck</string>
      <string original="Smartphone Graph">Smartphone Graph</string>
      <string original="Pressure-time diagram">Druck-Zeit-Diagramm</string>
      <string original="Measuring time">Messdauer</string>
      <string original="SensorTag Air Pressure Data">SensorTag Luftdruckwerte</string>
      <string original="Use this tab for measurements with the TI SensorTag pressure sensor.">Nutze diesen Tab für Messungen mit dem Drucksensor des TI SensorTag.</string>
      <string original="SensorTag Graph">SensorTag Graph</string>
      <string original="Smartphone Raw Data">Smartphone Rohdaten</string>
      <string original="Time (s)">Zeit (s)</string>
      <string original="Pressure (hPa)">Druck (hPa)</string>
      <string original="SensorTag Raw Data">SensorTag Rohdaten</string>
    </translation>
    <translation locale="fr">
      <title>Vérifier une atmosphère de vaisseau spatial</title>
      <category>*Astrolab University of Cologne</category>
      <description>
        Tester des prototypes de vaisseaux spatiaux construits en classe avec le capteur de pression de l'air.

        Dans cette expérience, la pression de l'air est utilisée comme analogie pour des questions d'atmosphère et de sécurité autour d'un prototype de vaisseau spatial. Différentes mesures sont effectuées et comparées à des valeurs de référence. Le montage est un modèle de salle de classe et non une simulation complète de mission.

        Le même fichier prend en charge soit le capteur de pression du téléphone, soit le capteur de pression du TI SensorTag. Les deux chaînes de mesure enregistrent la pression de l'air [hPa] en fonction du temps [s] et donnent la durée, la valeur maximale, la valeur minimale, la moyenne et l'amplitude de la chute de pression.
    </description>
      <string original="Smartphone Air Pressure Data">Données de pression du smartphone</string>
      <string original="Use this tab for measurements with the phone pressure sensor.">Utilise cet onglet pour les mesures avec le capteur de pression du téléphone.</string>
      <string original="Current value">Valeur actuelle</string>
      <string original="Maximum">Maximum</string>
      <string original="Minimum">Minimum</string>
      <string original="Maximum offset">Écart maximal</string>
      <string original="⌀ Air pressure">⌀ pression de l'air</string>
      <string original="Smartphone Graph">Graphique smartphone</string>
      <string original="Pressure-time diagram">Diagramme pression-temps</string>
      <string original="Measuring time">Durée de mesure</string>
      <string original="SensorTag Air Pressure Data">Données de pression SensorTag</string>
      <string original="Use this tab for measurements with the TI SensorTag pressure sensor.">Utilise cet onglet pour les mesures avec le capteur de pression du TI SensorTag.</string>
      <string original="SensorTag Graph">Graphique SensorTag</string>
      <string original="Smartphone Raw Data">Données brutes smartphone</string>
      <string original="Time (s)">Temps (s)</string>
      <string original="Pressure (hPa)">Pression (hPa)</string>
      <string original="SensorTag Raw Data">Données brutes SensorTag</string>
    </translation>
   </translations>
  <data-containers>
    <container size="0">phone_p</container>
    <container size="0">phone_p_max</container>
    <container size="0">phone_p_min</container>
    <container size="0">phone_p_diff</container>
    <container size="0">phone_p_avg</container>
    <container size="0">phone_t</container>
    <container size="0" static="false">phone_t_max</container>
    <container size="0" static="false">st_tempRaw</container>
    <container size="0" static="false">st_pRaw</container>
    <container size="0" static="false">st_tempCal</container>
    <container size="0" static="false">st_p</container>
    <container size="0" static="false">st_t</container>
    <container size="1" static="false">st_count</container>
    <container size="1" static="false">st_tmax</container>
    <container size="0">st_p_max</container>
    <container size="0">st_p_min</container>
    <container size="0">st_p_diff</container>
    <container size="0">st_p_avg</container>
    <container size="0" static="false">st_t_max</container>
  </data-containers>
  <input>
    <sensor type="pressure">
      <output component="t">phone_t</output>
      <output component="x">phone_p</output>
    </sensor>
    <bluetooth name="SensorTag" mode="notification" rate="1" subscribeOnStart="false">
      <config char="F000AA44-0451-4000-B000-000000000000" conversion="hexadecimal">0A</config>
      <config char="F000AA42-0451-4000-B000-000000000000" conversion="hexadecimal">01</config>
      <output char="F000AA41-0451-4000-B000-000000000000" conversion="uInt24LittleEndian" offset="3" length="3">st_pRaw</output>
      <output char="F000AA41-0451-4000-B000-000000000000" conversion="uInt24LittleEndian" offset="0" length="3">st_tempRaw</output>
    </bluetooth>
  </input>
  <analysis>
    <max>
      <input as="y" clear="false">phone_p</input>
      <output as="max">phone_p_max</output>
    </max>
    <min>
      <input as="y" clear="false">phone_p</input>
      <output as="min">phone_p_min</output>
    </min>
    <subtract>
      <input as="minuend" clear="false">phone_p_max</input>
      <input as="subtrahend" clear="false">phone_p_min</input>
      <output as="difference">phone_p_diff</output>
    </subtract>
    <average>
      <input as="buffer" clear="false">phone_p</input>
      <output as="average">phone_p_avg</output>
    </average>
    <max>
      <input as="y" clear="false">phone_t</input>
      <output as="max">phone_t_max</output>
    </max>
    <multiply>
      <input as="factor" clear="false">st_tempRaw</input>
      <input as="factor" type="value">0.01</input>
      <output as="product">st_tempCal</output>
    </multiply>
    <multiply>
      <input as="factor" clear="false">st_pRaw</input>
      <input as="factor" type="value">0.01</input>
      <output as="product">st_p</output>
    </multiply>
    <count>
      <input as="buffer" clear="false">st_tempRaw</input>
      <output as="count">st_count</output>
    </count>
    <formula formula="([1]-1)*0.1">
      <input as="in" clear="false">st_count</input>
      <output as="out">st_tmax</output>
    </formula>
    <ramp>
      <input as="start" type="value">0</input>
      <input as="stop">st_tmax</input>
      <input as="length">st_count</input>
      <output as="out">st_t</output>
    </ramp>
    <max>
      <input as="y" clear="false">st_p</input>
      <output as="max">st_p_max</output>
    </max>
    <min>
      <input as="y" clear="false">st_p</input>
      <output as="min">st_p_min</output>
    </min>
    <subtract>
      <input as="minuend" clear="false">st_p_max</input>
      <input as="subtrahend" clear="false">st_p_min</input>
      <output as="difference">st_p_diff</output>
    </subtract>
    <average>
      <input as="buffer" clear="false">st_p</input>
      <output as="average">st_p_avg</output>
    </average>
    <max>
      <input as="y" clear="false">st_t</input>
      <output as="max">st_t_max</output>
    </max>
  </analysis>
  <views>
    <view label="Smartphone Air Pressure Data">
      <info label ="Use this tab for measurements with the phone pressure sensor." />
      <separator height="1"/>
      <value label="Current value" size="2" precision="2" unit="hPa">
        <input>phone_p</input>
      </value>
      <value label="Maximum" size="2" precision="2" unit="hPa">
        <input>phone_p_max</input>
      </value>
      <value label="Minimum" size="2" precision="2" unit="hPa">
        <input>phone_p_min</input>
      </value>
      <value label="Maximum offset" size="2" precision="2" unit="hPa">
        <input>phone_p_diff</input>
      </value>
      <value label="⌀ Air pressure" size="2" precision="2" unit="hPa">
        <input>phone_p_avg</input>
      </value>
    </view>
    <view label="Smartphone Graph">
      <graph label="Pressure-time diagram" labelX="t" unitX="s" labelY="p" unitY="hPa" yPrecision="6" partialUpdate="true">
        <input axis="x">phone_t</input>
        <input axis="y">phone_p</input>
      </graph>
      <separator height="1"/>
      <value label="Measuring time" size="1" precision="1" scientific="false" unit="s" factor="1">
        <input>phone_t_max</input>
      </value>
    </view>
    <view label="SensorTag Air Pressure Data">
      <info label ="Use this tab for measurements with the TI SensorTag pressure sensor." />
      <separator height="1"/>
      <value label="Current value" size="2" precision="2" unit="hPa">
        <input>st_p</input>
      </value>
      <value label="Maximum" size="2" precision="2" unit="hPa">
        <input>st_p_max</input>
      </value>
      <value label="Minimum" size="2" precision="2" unit="hPa">
        <input>st_p_min</input>
      </value>
      <value label="Maximum offset" size="2" precision="2" unit="hPa">
        <input>st_p_diff</input>
      </value>
      <value label="⌀ Air pressure" size="2" precision="2" unit="hPa">
        <input>st_p_avg</input>
      </value>
    </view>
    <view label="SensorTag Graph">
      <graph label="Pressure-time diagram" labelX="t" unitX="s" labelY="p" unitY="hPa" yPrecision="6" partialUpdate="true">
        <input axis="x">st_t</input>
        <input axis="y">st_p</input>
      </graph>
      <separator height="1"/>
      <value label="Measuring time" size="1" precision="1" scientific="false" unit="s" factor="1">
        <input>st_t_max</input>
      </value>
    </view>
  </views>
  <export>
    <set name="Smartphone Raw Data">
      <data name="Time (s)">phone_t</data>
      <data name="Pressure (hPa)">phone_p</data>
    </set>
    <set name="SensorTag Raw Data">
      <data name="Time (s)">st_t</data>
      <data name="Pressure (hPa)">st_p</data>
    </set>
  </export>
</phyphox>
